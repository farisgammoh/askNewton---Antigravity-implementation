# ==============================================================================
# askNewton Environment Variables Template (.env.example)
# Use this as a reference for setting up local development or deployment secrets.
# Do NOT commit actual credentials or secret values to source control.
# ==============================================================================

# Required for server startup & authentication
JWT_SECRET=
JWT_REFRESH_SECRET=
SESSION_SECRET=
DATABASE_URL=

# Required for Postgres direct connection (if DATABASE_URL is not used)
PGHOST=
PGPORT=
PGDATABASE=
PGUSER=
PGPASSWORD=

# Required for ElevenLabs voice agent webhooks
ELEVEN_END_SECRET=
ELEVEN_INIT_SECRET=
ELEVENLABS_WEBHOOK_SECRET=

# Required for admin functions
ADMIN_API_KEY=

# Required for OpenAI features
OPENAI_API_KEY=

# Required for Waitlist features
AIRTABLE_TOKEN=
AIRTABLE_BASE_ID=
AIRTABLE_WAITLIST_TABLE=
HUBSPOT_TOKEN=
